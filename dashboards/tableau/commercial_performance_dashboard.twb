              <calculation class='tableau' formula='IF ZN(SUM([Calculation_0633055354826758])) = 0 THEN 0&#13;&#10;ELSE&#13;&#10;(ZN(SUM([Calculation_0633055334494213]))- ZN(SUM([Calculation_0633055354826758]))) / ZN(SUM([Calculation_0633055354826758]))&#13;&#10;END' />
