            <column caption='CY Revenue' datatype='integer' default-format='c&quot;$&quot;#,##0.00;-&quot;$&quot;#,##0.00' name='[Calculation_0633055334494213]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Calculation_0633055330664451] = [Parameters].[Parámetro 2] THEN [Ingresos]&#13;&#10;END' />
