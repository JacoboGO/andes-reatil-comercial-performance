          <formatted-text>
            <run fontalignment='1' fontname='Arial' fontsize='12'>It is shows the high sold units</run>
            <run fontalignment='1'>Æ&#10;</run>
            <run fontalignment='1' fontname='Arial' fontsize='8'><![CDATA[Low sold per ID order equals to < $1000 and High sold >= $1000]]></run>
          </formatted-text>
