            <column caption='ID order count' datatype='integer' name='[Calculation_0250427209166866]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD([ID_Pedido])' />
            </column>
            <column aggregation='Sum' caption='Date_Year' datatype='integer' name='[Calculation_0633055330664451]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='YEAR([Fecha_Pedido])' />
            </column>
            <column caption='PAR_CY DateYear' datatype='integer' name='[Calculation_0633055331946500]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED : MAX([Calculation_0633055330664451])}' />
            </column>
            <column caption='CY Revenue' datatype='integer' default-format='c&quot;$&quot;#,##0.00;-&quot;$&quot;#,##0.00' name='[Calculation_0633055334494213]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Calculation_0633055330664451] = [Parameters].[Parámetro 2] THEN [Ingresos]&#13;&#10;END' />
            </column>
            <column caption='PY Revenue' datatype='integer' default-format='c&quot;$&quot;#,##0,,.00M;(&quot;$&quot;#,##0,,.00M)' name='[Calculation_0633055354826758]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Calculation_0633055330664451] = [Parameters].[Parámetro 2] - 1 THEN [Ingresos]&#13;&#10;END' />
            </column>
            <column caption='Revenue Growth YoY %' datatype='real' default-format='*`▲ +0.0%;▼ -0.0%;0.0%`' name='[Calculation_0633055365357575]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF ZN(SUM([Calculation_0633055354826758])) = 0 THEN 0&#13;&#10;ELSE&#13;&#10;(ZN(SUM([Calculation_0633055334494213]))- ZN(SUM([Calculation_0633055354826758]))) / ZN(SUM([Calculation_0633055354826758]))&#13;&#10;END' />
            </column>
            <column caption='LBL_YoY_Positivo' datatype='real' default-format='*▲ +0.0%;▼ -0.0%' name='[Calculation_0633055465459722]' role='measure' type='quantitative'>
