            <column caption='CY Season - Month' datatype='string' datatype-customized='true' name='[CY Month (copia)_0830968175357958]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF MONTH([Calculation_0830968184762376] ) IN (1, 2) THEN &quot;Summer B&quot;&#13;&#10;ELSEIF MONTH([Calculation_0830968184762376]) IN (3, 4, 5) THEN &quot;Fall&quot;&#13;&#10;ELSEIF MONTH([Calculation_0830968184762376]) IN (6, 7, 8) THEN &quot;Winter&quot;&#13;&#10;ELSEIF MONTH([Calculation_0830968184762376]) IN (12) THEN &quot;Summer E&quot;&#13;&#10;ELSE &quot;Spring&quot;&#13;&#10;END' />
              <aliases>
                <alias key='&quot;Summer B&quot;' value='Summer Begin Year' />
                <alias key='&quot;Summer E&quot;' value='Summer End Year' />
              </aliases>
            </column>
            <column caption='ID customer count' datatype='integer' name='[Calculation_0250427208478737]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD([ID_Cliente])' />
