              <calculation class='tableau' formula='IF [Calculation_0633055330664451] = [Parameters].[Parámetro 2] THEN [Fecha_Pedido]&#13;&#10;END' />
            </column>
            <column aggregation='Sum' caption='CY orden season' datatype='integer' name='[Calculation_0830968189640713]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='CASE [CY Month (copia)_0830968175357958]&#13;&#10;WHEN &quot;Summer B&quot; THEN 1&#13;&#10;WHEN &quot;Fall&quot;     THEN 2&#13;&#10;WHEN &quot;Winter&quot;   THEN 3&#13;&#10;WHEN &quot;Spring&quot;   THEN 4&#13;&#10;WHEN &quot;Summer E&quot; THEN 5&#13;&#10;END' />
