              <calculation class='tableau' formula='IF [Calculation_0633055365357575] &lt; 0 THEN [Calculation_0633055365357575]&#13;&#10;END' />
            </column>
            <column caption='COL_CY_Gross Profit Margin' datatype='string' name='[Calculation_0671263911473153]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_0671263913521154] &lt; 0.35 THEN &quot;GPM &lt; 35%&quot; &#13;&#10;END' />
            </column>
            <column caption='CY Gross Profit Margin (%)' datatype='real' name='[Calculation_0671263913521154]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF ZN(SUM([Calculation_0633055334494213])) = 0 THEN 0&#13;&#10;ELSE&#13;&#10;(ZN(SUM([Calculation_0633055334494213]))-ZN(SUM([Calculation_0671263914766339])))/ZN(SUM([Calculation_0633055334494213]))&#13;&#10;END' />
            </column>
            <column caption='CY Cost' datatype='real' name='[Calculation_0671263914766339]' role='measure' type='quantitative'>
