              <calculation class='tableau' formula='2025' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1gp0l7b053v58j17wucj90lvv3mf'>
            <column caption='CY Season - Month' datatype='string' datatype-customized='true' name='[CY Month (copia)_0830968175357958]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF MONTH([Calculation_0830968184762376] ) IN (1, 2) THEN &quot;Summer B&quot;&#13;&#10;ELSEIF MONTH([Calculation_0830968184762376]) IN (3, 4, 5) THEN &quot;Fall&quot;&#13;&#10;ELSEIF MONTH([Calculation_0830968184762376]) IN (6, 7, 8) THEN &quot;Winter&quot;&#13;&#10;ELSEIF MONTH([Calculation_0830968184762376]) IN (12) THEN &quot;Summer E&quot;&#13;&#10;ELSE &quot;Spring&quot;&#13;&#10;END' />
              <aliases>
                <alias key='&quot;Summer B&quot;' value='Summer Begin Year' />
                <alias key='&quot;Summer E&quot;' value='Summer End Year' />
              </aliases>
            </column>
            <column aggregation='CountD' caption='nivel_venta' datatype='string' default-role='measure' default-type='quantitative' name='[Calculation_0250427101245440]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_0633055334494213] &lt; 1000 THEN &quot;Low sold&quot;&#13;&#10;ELSE &quot;High sold&quot;&#13;&#10;END' />
            </column>
            <column caption='ID customer count' datatype='integer' name='[Calculation_0250427208478737]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD([ID_Cliente])' />
            </column>
            <column caption='ID order count' datatype='integer' name='[Calculation_0250427209166866]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD([ID_Pedido])' />
            </column>
            <column aggregation='Sum' caption='Date_Year' datatype='integer' name='[Calculation_0633055330664451]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='YEAR([Fecha_Pedido])' />
            </column>
            <column caption='PAR_CY DateYear' datatype='integer' name='[Calculation_0633055331946500]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED : MAX([Calculation_0633055330664451])}' />
            </column>
            <column caption='CY Revenue' datatype='integer' default-format='c&quot;$&quot;#,##0.00;-&quot;$&quot;#,##0.00' name='[Calculation_0633055334494213]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Calculation_0633055330664451] = [Parameters].[Parámetro 2] THEN [Ingresos]&#13;&#10;END' />
            </column>
            <column caption='CY Sold Units' datatype='integer' name='[Calculation_0633055483138064]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Calculation_0633055330664451] = [Parameters].[Parámetro 2] THEN [Unidades_Vendidas]&#13;&#10;END' />
            </column>
            <column caption='Ratio efficiency cost' datatype='real' name='[Calculation_0675662540726276]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='ZN( {FIXED [Categoría_Producto] : SUM([Costo])}) /&#13;&#10;ZN( {FIXED [Categoría_Producto] : SUM([Ingresos])})' />
            </column>
            <column caption='COL_ratio_eficiency_cost' datatype='string' datatype-customized='true' name='[Calculation_0675662555021321]' role='dimension' type='nominal'>
