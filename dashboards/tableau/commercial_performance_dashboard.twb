              <calculation class='tableau' formula='ZN( {FIXED [Categoría_Producto] : SUM([Costo])}) /&#13;&#10;ZN( {FIXED [Categoría_Producto] : SUM([Ingresos])})' />
            </column>
            <column caption='COL_ratio_eficiency_cost' datatype='string' datatype-customized='true' name='[Calculation_0675662555021321]' role='dimension' type='nominal'>
